# Copy to .env.development and fill in real values. .env.* is gitignored.

# Supabase — iOS client uses these
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Presence backend (local dev)
BACKEND_URL=http://localhost:3000

# Anthropic — backend ONLY. Never include this in the iOS bundle.
ANTHROPIC_API_KEY=sk-ant-...

# RevenueCat — iOS SDK key
REVENUECAT_API_KEY=appl_...

# Copy to .env and fill in real values. .env is gitignored.

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Supabase (server-side — uses service role key, NEVER ship to client)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic (backend only — never include in iOS bundle)
ANTHROPIC_API_KEY=sk-ant-...

# CORS — comma-separated list of allowed origins for local dev.
# Leave empty to allow the iOS app (which doesn't send an Origin header anyway).
CORS_ORIGINS=http://localhost:3000
